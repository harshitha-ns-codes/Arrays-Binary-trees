#include <stdio.h>

int maxProduct(int arr[], int n)
{
    int maxEnd = arr[0];
    int minEnd = arr[0];
    int result = arr[0];

    for (int i = 1; i < n; i++)
    {
        if (arr[i] < 0)
        {
            int temp = maxEnd;
            maxEnd = minEnd;
            minEnd = temp;
        }

        maxEnd = (arr[i] > maxEnd * arr[i]) ? arr[i] : maxEnd * arr[i];
        minEnd = (arr[i] < minEnd * arr[i]) ? arr[i] : minEnd * arr[i];

        result = (result > maxEnd) ? result : maxEnd;
    }
    return result;
}

int main()
{
    int arr[] = {2, 3, -2, 4};
    int n = sizeof(arr) / sizeof(arr[0]);
    printf("Maximum product subarray = %d", maxProduct(arr, n));
    return 0;
}
