#include <bits/stdc++.h>
using namespace std;

vector<int> inorderItera(TreeNode* root)
{
    vector<int> ans;

    stack<TreeNode*> st;

    while(root != nullptr || !st.empty())
    {
        while(root != nullptr)
        {
            st.push(root);
            root = root->left;
        }

        root = st.top();
        st.pop();

        ans.push_back(root->val);

        root = root->right;
    }

    return ans;
}
