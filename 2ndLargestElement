#include <stdio.h>

int main()
{
    int arr[] = {12, 35, 1, 10, 34, 1};
    int n = 6;

    int largest = arr[0];
    int secondLargest = -1;

    for (int i = 1; i < n; i++)
    {
        if (arr[i] > largest)
        {
            secondLargest = largest;
            largest = arr[i];
        }
        else if (arr[i] > secondLargest && arr[i] != largest)
        {
            secondLargest = arr[i];
        }
    }

    printf("Second largest element = %d", secondLargest);
    return 0;
}
