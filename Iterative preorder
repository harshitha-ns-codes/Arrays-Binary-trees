#include <bits/stdc++.h>
using namespace std;

vector<int> preorderItera(TreeNode* root)
{
    vector<int>ans;

    stack<TreeNode*>st;
    if(root == nullptr)
    {
        return ans;
    }
    st.push(root);
    while(!st.empty())
    {
        root = st.top();
        st.pop();
        ans.push_back(root->val);
        if(root->right != nullptr)
        {
            st.push(root->right);
        }
        if(root->left != nullptr)
        {
            st.push(root->left);
        }
    }
    return ans;
}
